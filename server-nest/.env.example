# ─────────────────────────────────────────────────────────────
# HahaSNS — NestJS backend environment (copy to .env and fill in)
# Placeholders only. Do NOT commit real secrets.
# ─────────────────────────────────────────────────────────────

# HTTP
PORT=4000
# Reverse-proxy trust: leave unset for direct exposure (req.ip = socket IP).
# Behind nginx/panel set TRUST_PROXY=1 (or 'loopback') so req.ip reads X-Forwarded-For
# — required for per-IP registration rate-limiting to see the real client IP.
# TRUST_PROXY=1

# ── JWT ──
# 30-day tokens, same as the Express server. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=30d

# ── First-run admin bootstrap (optional) ──
# If BOTH are set and the DB has no admin yet, an admin is auto-created on boot
# (no manual SQL promote). Ignored once any admin exists. Change the password after first login.
# SEED_ADMIN_USER=admin
# SEED_ADMIN_PASSWORD=change-me-strong

# ── Database ──
# Driver switch: mysql (default) | postgres
DB_CLIENT=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=hahasns
DB_PASSWORD=change-me
DB_NAME=hahasns
# First deploy: set to true ONCE so TypeORM creates all tables from the entities
# (this project ships NO separate migration files — tables come from synchronize).
# After the tables exist, set it back to false so later starts can't alter the schema.
DB_SYNCHRONIZE=false
DB_LOGGING=false

# For PostgreSQL instead, set:
# DB_CLIENT=postgres
# DB_PORT=5432

# ── Redis cache ──
REDIS_URL=redis://127.0.0.1:6379
# default cache TTL in milliseconds
REDIS_TTL=30000

# ── S3-compatible object storage (rustfs / MinIO / AWS S3) ──
S3_ENDPOINT=http://127.0.0.1:9000
S3_BUCKET=hahasns
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me
S3_REGION=us-east-1
# rustfs / MinIO require path-style addressing
S3_FORCE_PATH_STYLE=true
# Optional public base URL (CDN / gateway) used to build returned media URLs.
# Leave blank to derive from S3_ENDPOINT + bucket.
S3_PUBLIC_URL=

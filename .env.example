# HahaSNS 环境变量示例 —— 复制为 .env 后按需修改（docker compose / 宝塔 / 1Panel 通用）
# 生成强随机串：node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"

JWT_SECRET=请改成一段强随机字符串
DB_PASSWORD=请改成一段数据库密码        # MariaDB 的 hahasns 用户密码
# DB_ROOT_PASSWORD=                     # 可选：MariaDB root 密码（不填则复用 DB_PASSWORD）
APP_PORT=4000            # 容器对外（本机）端口，端口冲突就改这里
# 大陆服务器构建加速：取消下一行注释（用 npm 国内镜像；国外保持注释即可）
# NPM_REGISTRY=https://registry.npmmirror.com
# ANTHROPIC_API_KEY=     # 可选：配置后启用 AI 助手；不配则 AI 走演示占位
# S3_ENDPOINT= / S3_BUCKET= / S3_ACCESS_KEY= / S3_SECRET_KEY=  # 可选：配了走对象存储，否则上传存本地卷
